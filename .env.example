PROMETHEUS_URL=http://10.100.0.142:9090
LOKI_URL=http://10.100.0.142:3100

GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=alerts@example.com
SMTP_TO=team@example.com
SMTP_USE_TLS=true

LOOKBACK_MINUTES=60
MAX_LOG_LINES=50
MAX_LOG_CHARS=3000

# --- Security (set these in production) ---
# Shared secret Grafana must send as `Authorization: Bearer <token>` or `X-Webhook-Token`.
WEBHOOK_TOKEN=
# API key required to pull PDF reports, sent as `X-API-Key` or bearer token.
REPORTS_API_KEY=

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- Resilience: outbound timeouts and retries ---
HTTP_TIMEOUT_SECONDS=15
HTTP_MAX_RETRIES=3
GROQ_TIMEOUT_SECONDS=45
GROQ_MAX_RETRIES=3

# --- Deep incident analysis windows / thresholds (optional) ---
INCIDENT_WINDOW_MINUTES=30
PRE_WINDOW_MINUTES=30
POST_WINDOW_MINUTES=15
BASELINE_WINDOW_MINUTES=120
BASELINE_OFFSET_MINUTES=60
ANALYSIS_STEP_SECONDS=60
ANOMALY_CONFIRM_RATIO=3.0
ANOMALY_PROBABLE_RATIO=1.8
ANOMALY_POSSIBLE_RATIO=1.25
MIN_EVIDENCE_SCORE=3.0
